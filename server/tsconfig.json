{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "target": "es2022",
    "types": [],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include" : ["src/**/*", "src/data/**/*.json"]
}
